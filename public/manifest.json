{
  "author": "purepotential",
  "name": "Readwise Reader Sync",
  "description": "Sync your Readwise Reader highlights with RemNote",
  "enableOnMobile": true,
  "id": "purepotential-readwise-reader",
  "manifestVersion": 1,
  "repoUrl": "https://github.com/purepotential/remnote-readwise",
  "version": {
    "major": 0,
    "minor": 0,
    "patch": 27
  },
  "minimumRemNoteVersion": {
    "major": 1,
    "minor": 8,
    "patch": 69
  },
  "requestNative": false,
  "requiredScopes": [
    {
      "type": "All",
